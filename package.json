{
  "name": "codeshot",
  "version": "0.1.0",
  "description": "Generate PNG screenshots of code snippets with syntax highlighting",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "codeshot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "keywords": [
    "code",
    "screenshot",
    "syntax-highlighting",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "commander": "^14.0.3",
    "shiki": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
